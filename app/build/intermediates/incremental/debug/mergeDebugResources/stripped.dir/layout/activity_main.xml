<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aaradhya_bg">

    <!-- Active Overlay -->
    <View
        android:id="@+id/redOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/aaradhya_amber"
        android:alpha="0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="40dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <!-- Left: Battery -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/batteryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋 --"
                    android:textColor="@color/aaradhya_teal"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Center: Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AARADHYA"
                    android:textColor="@color/aaradhya_gold"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLASSIFIED SYSTEM"
                    android:textColor="@color/aaradhya_gold_dim"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.2" />
            </LinearLayout>

            <!-- Right: Time + Settings -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/aaradhya_gold2"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/settingsBtn"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/aaradhya_gold_dim"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:contentDescription="Settings" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/aaradhya_border2" />

        <!-- ORB AREA -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <!-- Background Grid (Optional, simple tiled background could be done via drawable) -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <com.aaradhya.assistant.ui.main.OrbAnimationView
                    android:id="@+id/orbView"
                    android:layout_width="280dp"
                    android:layout_height="280dp" />

                <com.aaradhya.assistant.ui.main.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="200dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="○ ONLINE"
                    android:textColor="@color/aaradhya_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </FrameLayout>

        <!-- MIC BUTTON AREA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/aaradhya_bg"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_mic_button"
                android:src="@drawable/ic_mic_on"
                android:contentDescription="Microphone"
                android:elevation="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="FatihMakes Industries · [TAP] MUTE"
                android:textColor="@color/aaradhya_text3"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>

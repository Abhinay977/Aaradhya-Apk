<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="aaradhya_amber">#ff7b00</color>
    <color name="aaradhya_bg">#05070f</color>
    <color name="aaradhya_border">#1a2040</color>
    <color name="aaradhya_border2">#253060</color>
    <color name="aaradhya_cyan">#00e5cc</color>
    <color name="aaradhya_gold">#f0a500</color>
    <color name="aaradhya_gold2">#ffd060</color>
    <color name="aaradhya_gold_dim">#7a5200</color>
    <color name="aaradhya_gold_pale">#3d2900</color>
    <color name="aaradhya_green">#00ff99</color>
    <color name="aaradhya_purple">#ff4500</color>
    <color name="aaradhya_purple_dark">#2a1800</color>
    <color name="aaradhya_red">#ff3355</color>
    <color name="aaradhya_red_dark">#7a4000</color>
    <color name="aaradhya_surface">#0a0e1a</color>
    <color name="aaradhya_surface2">#0f1422</color>
    <color name="aaradhya_teal">#00e5cc</color>
    <color name="aaradhya_teal_dim">#007060</color>
    <color name="aaradhya_text">#c8d4e8</color>
    <color name="aaradhya_text2">#7080a0</color>
    <color name="aaradhya_text3">#3a4560</color>
    <string name="accessibility_description">AARADHYA needs accessibility to perform actions on your behalf like opening apps, making calls, and navigating the phone.</string>
    <string name="app_description">AI Voice Assistant</string>
    <string name="app_name">AARADHYA</string>
    <string name="mic_button_desc">Microphone button — tap to mute, long press to interrupt AARADHYA</string>
    <string name="settings_button_desc">Open settings</string>
    <style name="Theme.AARADHYA" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/aaradhya_gold</item>
        <item name="colorPrimaryVariant">@color/aaradhya_gold_dim</item>
        <item name="colorOnPrimary">@color/aaradhya_bg</item>
        <item name="colorSecondary">@color/aaradhya_teal</item>
        <item name="colorOnSecondary">@color/aaradhya_bg</item>
        <item name="android:colorBackground">@color/aaradhya_bg</item>
        <item name="colorSurface">@color/aaradhya_surface</item>
        <item name="colorOnSurface">@color/aaradhya_text</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/aaradhya_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="alertDialogTheme">@style/Theme.AARADHYA.Dialog</item>
    </style>
    <style name="Theme.AARADHYA.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/aaradhya_gold</item>
        <item name="android:textColor">@color/aaradhya_bg</item>
    </style>
    <style name="Theme.AARADHYA.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/aaradhya_gold_dim</item>
        <item name="android:textColor">@color/aaradhya_gold</item>
    </style>
    <style name="Theme.AARADHYA.Dialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:colorBackground">@color/aaradhya_surface</item>
        <item name="colorPrimary">@color/aaradhya_gold</item>
        <item name="android:textColorPrimary">@color/aaradhya_text</item>
        <item name="buttonBarPositiveButtonStyle">@style/Theme.AARADHYA.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Theme.AARADHYA.Button.Outlined</item>
    </style>
</resources>